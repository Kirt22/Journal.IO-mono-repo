PORT=3000
HOST=0.0.0.0
NODE_ENV=development
MONGO_STAGE=local
MONGO_URI=mongodb://localhost:27017/journal_io
LOG_FULL_MONGO_URI=false

JWT_ACCESS_SECRET=replace_me
JWT_ACCESS_EXPIRES_IN=14d
JWT_REFRESH_EXPIRES_IN=7d
AUTH_EMAIL_OTP_EXPIRES_IN=30m
AUTH_PASSWORD_RESET_EXPIRES_IN=30m
AUTH_PASSWORD_RESET_APP_URL=http://localhost:3000/reset-password
AUTH_EMAIL_DELIVERY_MODE=console
AUTH_EMAIL_FROM_ADDRESS=otp@mail.journalio.app
AUTH_EMAIL_FROM_NAME=Journal.IO
AUTH_EMAIL_REPLY_TO=
AUTH_EMAIL_HELO_HOST=localhost

RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=465
RESEND_SMTP_USERNAME=resend
RESEND_SMTP_PASSWORD=replace_me

# Production Render overrides:
# AUTH_PASSWORD_RESET_APP_URL=https://api.journalio.app/reset-password
# AUTH_EMAIL_DELIVERY_MODE=smtp
# AUTH_EMAIL_FROM_ADDRESS=otp@mail.journalio.app
# AUTH_EMAIL_FROM_NAME=Journal.IO
# AUTH_EMAIL_REPLY_TO=
# AUTH_EMAIL_HELO_HOST=api.journalio.app
# RESEND_SMTP_HOST=smtp.resend.com
# RESEND_SMTP_PORT=465
# RESEND_SMTP_USERNAME=resend
# RESEND_SMTP_PASSWORD=re_xxxxxxxxx

GOOGLE_WEB_CLIENT_ID= abcd
GOOGLE_IOS_CLIENT_ID= abcd
GOOGLE_WEB_CLIENT_SECRET= abcd
APPLE_CLIENT_ID=app.journalio

OPENAI_API_KEY=replace_me
OPENAI_RESPONSES_MODEL=gpt-5.4-mini
AI_INSIGHTS_EXPERIMENTAL_EARLY_READY=false

REVENUECAT_WEBHOOK_AUTH_TOKEN=replace_me
REVENUECAT_SECRET_API_KEY=replace_me
REVENUECAT_APP_ID=replace_me
REVENUECAT_ALLOWED_WEBHOOK_ENVIRONMENTS=PRODUCTION,SANDBOX
