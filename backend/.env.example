PORT=3000
NODE_ENV=development
MONGO_STAGE=local
MONGO_URI=mongodb://localhost:27017/journal_io

JWT_ACCESS_SECRET=replace_me
JWT_ACCESS_EXPIRES_IN=14d
JWT_REFRESH_EXPIRES_IN=7d
AUTH_OTP_EXPIRES_IN=10m
AUTH_EMAIL_OTP_EXPIRES_IN=30m
AUTH_EMAIL_DELIVERY_MODE=console
AUTH_EMAIL_FROM_ADDRESS=onboarding@resend.dev
AUTH_EMAIL_FROM_NAME=Journal.IO
AUTH_EMAIL_REPLY_TO=
AUTH_EMAIL_HELO_HOST=localhost

RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=465
RESEND_SMTP_USERNAME=resend
RESEND_SMTP_PASSWORD=replace_me

MSG91_AUTH_KEY=replace_me
MSG91_TEMPLATE_ID=replace_me
MSG91_OTP_API_URL=https://control.msg91.com/api/v5/otp

GOOGLE_WEB_CLIENT_ID= abcd
GOOGLE_IOS_CLIENT_ID= abcd
GOOGLE_WEB_CLIENT_SECRET= abcd

OPENAI_API_KEY=replace_me
OPENAI_RESPONSES_MODEL=gpt-5.4-mini
